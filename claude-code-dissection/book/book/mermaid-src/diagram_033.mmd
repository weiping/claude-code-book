flowchart TD
    Input["工具调用请求
(工具名 + 参数)"]
    L1["第 1 层：规则引擎
<1ms，同步
模式匹配"]
    L2["第 2 层：AI 分类器
50-200ms，异步
上下文理解"]
    L3["第 3 层：用户确认
实时，交互式
最终决策者"]
    Allow["✅ 执行"]
    Deny["❌ 拒绝"]

    Input --> L1
    L1 -->|"明确允许"| Allow
    L1 -->|"明确拒绝"| Deny
    L1 -->|"不确定"| L2
    L2 -->|"允许（有把握）"| Allow
    L2 -->|"拒绝（有把握）"| Deny
    L2 -->|"不确定"| L3
    L3 -->|"用户批准"| Allow
    L3 -->|"用户拒绝"| Deny
