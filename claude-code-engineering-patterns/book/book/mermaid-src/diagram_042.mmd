flowchart TD
    SP["System Prompt（数万 token）"]
    SP --> SPLIT["splitSysPromptPrefix()"]

    SPLIT --> STATIC["静态前缀（工具描述 + CLI 系统提示）\ncacheScope = 'org'\n→ API 端 cache_control = 'ephemeral'"]
    SPLIT --> DYNAMIC["动态后缀（用户记忆 + CLAUDE.md + 工具命令）\n越过 SYSTEM_PROMPT_DYNAMIC_BOUNDARY 标记\n不缓存"]

    MSGS["消息历史（Message[]）"]
    MSGS --> CB["addCacheBreakpoints()"]
    CB --> LAST["最后一条消息\n添加 cache_control 标记（唯一一个）"]
    CB --> REST["其余消息\n无 cache_control"]

    STATIC -->|"第一次发送"| CC["cache_creation_input_tokens\n成本高"]
    STATIC -->|"后续命中"| CR["cache_read_input_tokens\n成本低"]
    DYNAMIC -->|"每次计费"| IT["input_tokens\n普通费率"]
