graph LR
    subgraph AGENT["Claude Code Agent（同一进程）"]
        CORE["核心循环\nquery.ts"]
        REPL["REPL.tsx\n终端界面"]
        BRIDGE["Bridge\n32 个文件"]
        LSP["LSP 服务\n7 个文件"]
    end

    subgraph TERMINAL["终端用户"]
        TTY["交互式终端\nInk/React"]
    end

    subgraph IDE["IDE / 网页"]
        CCR["Claude.ai 网页\nVS Code 扩展"]
        LS["Language Server\nrust-analyzer/pyright"]
    end

    TTY <-->|"stdin/stdout"| REPL
    REPL <-->|"React state"| CORE
    CORE <-->|"React state"| BRIDGE
    BRIDGE <-->|"SSE + WebSocket\nCCR 协议"| CCR
    LSP <-->|"JSON-RPC\nstdio"| LS
    LSP -->|"诊断注入 AppState"| CORE
