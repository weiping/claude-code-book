flowchart TD
    Caller["调用方（QueryEngine、REPL 等）"]
    GetSet["get/set 函数对（210 个导出函数）"]
    AtomicOp["原子操作函数（switchSession 等）"]
    STATE["STATE 对象（模块级，不导出）"]

    Caller -->|"读状态"| GetSet
    Caller -->|"写状态"| GetSet
    Caller -->|"复合写操作"| AtomicOp
    GetSet --> STATE
    AtomicOp --> STATE

    style STATE fill:#e8f5e9,stroke:#388e3c
    style GetSet fill:#e3f2fd,stroke:#1565c0
    style AtomicOp fill:#fff3e0,stroke:#e65100
